# =============================================================================
# CodeSheriff — Environment Variables
# Copy this file to .env and fill in values for local development
# =============================================================================

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://codesheriff:codesheriff@localhost:5432/codesheriff

# Redis
REDIS_URL=redis://localhost:6379

# Auth (Clerk)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab
GITLAB_APP_ID=
GITLAB_APP_SECRET=
GITLAB_WEBHOOK_SECRET=

# Bitbucket
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
BITBUCKET_WEBHOOK_SECRET=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# AWS S3 (scan artifacts & reports)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=codesheriff-artifacts
AWS_REGION=us-east-1

# Notifications
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
RESEND_API_KEY=
DIGEST_FROM_EMAIL=digest@yourdomain.com

# Public app URL (used in email links + onboarding GitHub App install URL)
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_APP_SLUG=codesheriff

# Token encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=

# Feature flags
ENABLE_HALLUCINATION_DETECTION=true
ENABLE_AUTH_VALIDATION=true
ENABLE_LOGIC_BUG_DETECTION=true
MAX_FILES_PER_SCAN=50
MAX_LINES_PER_FILE=1000

# Security
WEBHOOK_SIGNATURE_TOLERANCE_MS=300000
LLM_CACHE_TTL_SECONDS=3600
