# =============================================================================
# CodeSheriff — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://codesheriff:codesheriff@localhost:5432/codesheriff

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Anthropic (Claude — AI detectors)
# Get your key at: https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Clerk (Authentication)
# Get keys at: https://dashboard.clerk.com → API Keys
# -----------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# GitHub App
# Create at: https://github.com/settings/apps/new
# Required permissions: Contents (read), Pull requests (read/write),
#   Checks (read/write), Webhooks
# -----------------------------------------------------------------------------
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
# Slug shown in GitHub App URL: github.com/apps/<slug>
NEXT_PUBLIC_GITHUB_APP_SLUG=codesheriff-dev

# -----------------------------------------------------------------------------
# GitLab (optional — for GitLab integration)
# -----------------------------------------------------------------------------
GITLAB_WEBHOOK_SECRET=your-gitlab-webhook-secret-here
GITLAB_BASE_URL=https://gitlab.com

# -----------------------------------------------------------------------------
# Resend (email digests)
# Get your key at: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
DIGEST_FROM_EMAIL=digest@codesheriff.dev

# -----------------------------------------------------------------------------
# Token encryption (AES-256-GCM for VCS tokens at rest)
# Generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-key-here

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development
# Comma-separated additional CORS origins (optional)
ADDITIONAL_CORS_ORIGINS=

# -----------------------------------------------------------------------------
# Worker
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Analysis limits
# -----------------------------------------------------------------------------
MAX_FILES_PER_SCAN=50
MAX_LINES_PER_FILE=1000

# -----------------------------------------------------------------------------
# Feature flags (set to "false" to disable LLM detectors — useful for testing)
# -----------------------------------------------------------------------------
ENABLE_HALLUCINATION_DETECTION=true
ENABLE_AUTH_VALIDATION=true
ENABLE_LOGIC_BUG_DETECTION=true

# -----------------------------------------------------------------------------
# Webhook
# -----------------------------------------------------------------------------
WEBHOOK_SIGNATURE_TOLERANCE_MS=300000

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
CODESHERIFF_TEST_SECRET=test-secret-for-local-only
