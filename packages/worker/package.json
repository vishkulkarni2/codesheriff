{
  "name": "@codesheriff/worker",
  "version": "0.1.0",
  "private": true,
  "description": "CodeSheriff BullMQ scan worker",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codesheriff/analyzer": "workspace:*",
    "@codesheriff/db": "workspace:*",
    "@codesheriff/shared": "workspace:*",
    "@octokit/app": "^14.0.0",
    "@octokit/rest": "^20.0.0",
    "bullmq": "^5.4.0",
    "ioredis": "^5.3.2",
    "pino": "^9.2.0",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
